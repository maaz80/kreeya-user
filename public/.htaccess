# ================================================================
# SECURITY & PERFORMANCE .htaccess (FINAL STABLE VERSION)
# ================================================================

# ----------------------------------------------------------------
# 1. DISABLE DIRECTORY LISTING & SERVER SIGNATURE
# ----------------------------------------------------------------
Options -Indexes
ServerSignature Off

# ----------------------------------------------------------------
# 2. REWRITE ENGINE
# ----------------------------------------------------------------
RewriteEngine On
RewriteBase /

# Route sitemap.xml to the dynamic sitemap.php script
# RewriteRule ^sitemap\.xml$ sitemap.php [L]

# 301 Redirect old /service and /service/[slug] to /services and /services/[slug]
RewriteRule ^service$ /services [R=301,L]
RewriteRule ^service/(.*)$ /services/$1 [R=301,L]

# ----------------------------------------------------------------
# 3. BLOCK BAD BOTS & EMPTY USER AGENTS
# ----------------------------------------------------------------
<IfModule mod_rewrite.c>
     RewriteCond %{HTTP_USER_AGENT} (curl|wget|python|nikto|sqlmap|masscan|zgrab|nmap|dirbuster|gobuster|wfuzz|hydra|metasploit) [NC,OR]
     RewriteCond %{HTTP_USER_AGENT} ^-?$ [NC]
     RewriteRule .* - [F,L]
</IfModule>

# ----------------------------------------------------------------
# 4. BLOCK MALICIOUS REQUEST METHODS
# ----------------------------------------------------------------
<IfModule mod_rewrite.c>
     RewriteCond %{REQUEST_METHOD} ^(TRACE|TRACK|DELETE|PATCH|PUT|CONNECT) [NC]
     RewriteRule .* - [F,L]
</IfModule>

# ----------------------------------------------------------------
# 5. BLOCK SQL INJECTION & XSS IN URL
# ----------------------------------------------------------------
<IfModule mod_rewrite.c>
     RewriteCond %{QUERY_STRING} (\<|%3C).*script.*(\>|%3E) [NC,OR]
     RewriteCond %{QUERY_STRING} GLOBALS(=|\[|\%[0-9A-Z]{0,2}) [OR]
     RewriteCond %{QUERY_STRING} _REQUEST(=|\[|\%[0-9A-Z]{0,2}) [OR]
     RewriteCond %{QUERY_STRING} (union|select|insert|drop|delete|update|cast|create|char|convert|alter|declare|order|exec|set\+name) [NC,OR]
     RewriteCond %{QUERY_STRING} (\.\./|\.\.%2F|%2E%2E%2F) [NC]
     RewriteRule .* - [F,L]
</IfModule>

# ----------------------------------------------------------------
# 6. BLOCK SENSITIVE FILES
# ----------------------------------------------------------------
<FilesMatch "(^\.|\.(env|git|svn|htpasswd|htaccess|log|bak|backup|sql|db|sqlite)|package(-lock)?\.json$|vite\.config\.js$|eslint\.config\.js$|postcss\.config\.js$|tailwind\.config\.js$|README\.md$|Js-Bundle\.html$|bundle-stats\.html$)">
     Require all denied
</FilesMatch>

# ----------------------------------------------------------------
# 7. BLOCK SERVER-SIDE SCRIPT EXECUTION
# ----------------------------------------------------------------
 <FilesMatch ".(php3|php4|php5|phtml|pl|py|jsp|asp|aspx|sh|cgi|rb)$">
         Require all denied
    </FilesMatch>

    # Block all PHP files by default
    <FilesMatch ".php$">
         Require all denied
    </FilesMatch>

    # Allow only our index.php and sitemap.php scripts
    <Files "index.php">
         Require all granted
    </Files>

    <Files "sitemap.php">
         Require all granted
    </Files>

# ----------------------------------------------------------------
# 8. WWW → NON-WWW REDIRECT
# ----------------------------------------------------------------
<IfModule mod_rewrite.c>
     RewriteCond %{HTTP_HOST} ^www\.(.+)$ [NC]
     RewriteRule ^ https://%1%{REQUEST_URI} [R=301,L]
</IfModule>

# ----------------------------------------------------------------
# 9. HTTP → HTTPS REDIRECT
# ----------------------------------------------------------------
<IfModule mod_rewrite.c>
     RewriteCond %{HTTPS} off
     RewriteRule ^(.*)$ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]
</IfModule>

# ----------------------------------------------------------------
# 302 REDIRECTS FOR OLD PAGES (Page Delete & Page Rename)
# ----------------------------------------------------------------
<IfModule mod_alias.c>
     Redirect 301 /contact /contact-us
     Redirect 301 /about /about-us
     Redirect 301 /blogs /category/blogs
     Redirect 301 /portfolio_beyekls /portfolio-beyekls
     Redirect 301 /portfolio_coinpay /portfolio-coinpay
     Redirect 301 /portfolio_daccord /portfolio-daccord
     Redirect 301 /portfolio_nectar /portfolio-nectar
     Redirect 301 /policy /privacy-policy
     Redirect 301 /portfolio_beyekls /portfolio-beyekls
     Redirect 301 /ui-ux-design-service-in-delhi-for-saas /ui-ux-design-company-in-delhi-for-saas
     Redirect 301 /ui-ux-design-service-in-delhi-for-e-commerce /ui-ux-design-company-in-delhi-for-e-commerce
     Redirect 301 /ui-ux-design-ccompany-in-delhi-for-e-commerce /ui-ux-design-company-in-delhi-for-e-commerce
     Redirect 301 /ui-ux-design-service-in-delhi-for-real-estate /ui-ux-design-company-in-delhi-for-real-estate
     Redirect 301 /ui-ux-design-service-in-delhi-for-healthcare /ui-ux-design-company-in-delhi-for-healthcare
     Redirect 301 /ui-ux-design-service-in-delhi-for-fintech /ui-ux-design-company-in-delhi-for-fintech
     Redirect 301 /product-design-service-in-delhi-for-fintech /product-design-company-in-delhi-for-fintech
     Redirect 301 /product-design-service-in-delhi-for-healthcare /product-design-company-in-delhi-for-healthcare
     Redirect 301 /product-design-service-in-delhi-for-e-commerce /product-design-company-in-delhi-for-e-commerce
     Redirect 301 /%7Bsearch_term_string%7D /
     Redirect 301 /index /
     Redirect 301 /blogs_details/leading_uiux_design_companies_in_gurgaon_for_web_mobile_app_design_kreeya_design /leading-uiux-design-companies-in-gurgaon-for-web-mobile-app-design
     Redirect 301 /blogs_details/why_hiring_a_ui_ux_design_expert_can_transform_your_business_website /why-hiring-a-ui-ux-design-expert-can-transform-your-business-website
     Redirect 301 /blogs_details/best_uiux_design_agency_in_delhi_key_features_to_look_for /best-uiux-design-agency-in-delhi-key-features-to-look-for
     Redirect 301 /blogs_details/top_benefits_of_working_with_a_professional_ui_ux_design_expert /top-benefits-of-working-with-a-professional-ui-ux-design-expert
</IfModule>

# ----------------------------------------------------------------
# 10. REACT ROUTER FALLBACK
# ----------------------------------------------------------------
<IfModule mod_rewrite.c>
     RewriteRule ^index\.php$ - [L]
     RewriteCond %{REQUEST_FILENAME} !-f
     RewriteCond %{REQUEST_FILENAME} !-d
     RewriteRule . /index.php [L]
</IfModule>

# ----------------------------------------------------------------
# 11. SECURITY HEADERS (CLEANED & FIXED)
# ----------------------------------------------------------------
<IfModule mod_headers.c>

     # HSTS
     Header always set Strict-Transport-Security "max-age=31536000; includeSubDomains; preload" env=HTTPS

     # Prevent MIME sniffing
     Header always set X-Content-Type-Options "nosniff"

     # Clickjacking protection
     Header always set X-Frame-Options "SAMEORIGIN"

     # Referrer Policy
     Header always set Referrer-Policy "strict-origin-when-cross-origin"

     # Disable legacy XSS auditor
     Header always set X-XSS-Protection "0"

     # Permissions Policy
    Header always set Permissions-Policy "accelerometer=(), autoplay=*, camera=(), display-capture=(), encrypted-media=*, fullscreen=*, geolocation=(), gyroscope=(), magnetometer=(), microphone=(), midi=(), payment=(), picture-in-picture=*, publickey-credentials-get=(), screen-wake-lock=(), usb=(), web-share=*"

     # Content Security Policy (Comprehensive Google/Ads Fix)
     Header always set Content-Security-Policy "default-src 'self'; \
          base-uri 'self'; \
          object-src 'none'; \
          frame-ancestors 'self' https://www.google.com https://*.google.com; \
          form-action 'self' https://api.hsforms.com; \
          script-src 'self' 'unsafe-inline' \
               https://www.googletagmanager.com \
               https://www.google-analytics.com \
               https://connect.facebook.net \
               https://pagead2.googlesyndication.com \
               https://googleads.g.doubleclick.net \
               https://tpc.googlesyndication.com \
               https://*.adtrafficquality.google; \
          style-src 'self' 'unsafe-inline' \
               https://fonts.googleapis.com \
               https://cdnjs.cloudflare.com; \
          img-src 'self' data: blob: \
               https://res.cloudinary.com \
               https://www.googletagmanager.com \
               https://www.google-analytics.com \
               https://www.facebook.com \
               https://googleads.g.doubleclick.net \
               https://*.googlesyndication.com \
               https://img.youtube.com \
               https://*.ytimg.com \
               https://*.adtrafficquality.google; \
          font-src 'self' data: \
               https://fonts.gstatic.com \
               https://cdnjs.cloudflare.com; \
          connect-src 'self' \
               https://api.kreeyadesign.com \
               https://api.hsforms.com \
               https://www.google-analytics.com \
               https://region1.google-analytics.com \
               https://analytics.google.com \
               https://stats.g.doubleclick.net \
               https://www.facebook.com \
               https://*.adtrafficquality.google \
               https://pagead2.googlesyndication.com \
               https://*.googlesyndication.com \
               https://googleads.g.doubleclick.net \
               https://capig.datah04.com \
               https://csi.gstatic.com \
               https://region1.analytics.google.com \
               https://www.googletagmanager.com; \
          media-src 'self' blob: \
               https://res.cloudinary.com; \
          frame-src 'self' \
               https://www.googletagmanager.com \
               https://googleads.g.doubleclick.net \
               https://*.googlesyndication.com \
               https://*.adtrafficquality.google \
               https://www.google.com \
               https://www.youtube.com \
               https://www.youtube-nocookie.com; \
          worker-src 'self' blob:; \
          manifest-src 'self'; \
          upgrade-insecure-requests"

</IfModule>

# ----------------------------------------------------------------
# 12. REMOVE SERVER INFO HEADERS
# ----------------------------------------------------------------
<IfModule mod_headers.c>
     Header unset X-Powered-By
     Header unset Server
     Header always unset X-Powered-By
</IfModule>

# ----------------------------------------------------------------
# 13. BROWSER CACHING
# ----------------------------------------------------------------
# Define MIME types explicitly to ensure mod_expires works correctly on Hostinger shared hosting
<IfModule mod_mime.c>
     AddType image/x-icon .ico
     AddType font/ttf .ttf
     AddType font/otf .otf
     AddType font/woff .woff
     AddType font/woff2 .woff2
</IfModule>

<IfModule mod_expires.c>
     ExpiresActive On
     ExpiresByType image/jpg          "access plus 1 year"
     ExpiresByType image/jpeg         "access plus 1 year"
     ExpiresByType image/png          "access plus 1 year"
     ExpiresByType image/webp         "access plus 1 year"
     ExpiresByType image/gif          "access plus 1 year"
     ExpiresByType image/svg+xml      "access plus 1 year"
     ExpiresByType image/x-icon       "access plus 1 year"
     ExpiresByType font/woff2         "access plus 1 year"
     ExpiresByType font/woff          "access plus 1 year"
     ExpiresByType font/ttf           "access plus 1 year"
     ExpiresByType font/otf           "access plus 1 year"
     ExpiresByType text/css           "access plus 1 year"
     ExpiresByType application/javascript "access plus 1 year"
</IfModule>

<IfModule mod_headers.c>
     # Static assets — long cache (using 'always' to override Hostinger default headers)
     <FilesMatch "\.(?:js|css|webp|png|jpg|jpeg|gif|svg|ico|woff2?|ttf|otf|mp4)$">
          Header set Cache-Control "public, max-age=31536000, immutable"
          Header always set Cache-Control "public, max-age=31536000, immutable"
     </FilesMatch>

     # HTML/JSON — no cache
     <FilesMatch "\.(?:html|json|xml|txt)$">
          Header set Cache-Control "no-cache, no-store, must-revalidate"
          Header always set Cache-Control "no-cache, no-store, must-revalidate"
          Header set Pragma "no-cache"
          Header set Expires "0"
     </FilesMatch>
</IfModule>

# ----------------------------------------------------------------
# 14. GZIP COMPRESSION
# ----------------------------------------------------------------
<IfModule mod_deflate.c>
     AddOutputFilterByType DEFLATE text/html
     AddOutputFilterByType DEFLATE text/css
     AddOutputFilterByType DEFLATE application/javascript
     AddOutputFilterByType DEFLATE application/json
     AddOutputFilterByType DEFLATE image/svg+xml
     AddOutputFilterByType DEFLATE font/woff2
     AddOutputFilterByType DEFLATE font/woff

     # Don't compress already compressed files
     SetEnvIfNoCase Request_URI \.(gif|jpg|jpeg|png|webp|ico|mp4|woff2)$ no-gzip
</IfModule>

# ----------------------------------------------------------------
# 15. RATE LIMITING (if mod_ratelimit available)
# ----------------------------------------------------------------
<IfModule mod_ratelimit.c>
     <Location "/api">
          SetOutputFilter RATE_LIMIT
          SetEnv rate-limit 400
     </Location>
</IfModule>

# ----------------------------------------------------------------
# 16. HOTLINK PROTECTION (images)
# ----------------------------------------------------------------
<IfModule mod_rewrite.c>
     RewriteCond %{HTTP_REFERER} !^$
     RewriteCond %{HTTP_REFERER} !^https://(www\.)?kreeyadesign\.com [NC]
     RewriteRule \.(jpg|jpeg|png|gif|webp|svg|mp4)$ - [F,L]
</IfModule>